PORT=5000

JWT_SECRET=troque_esta_chave
JWT_EXPIRES_IN=1d

# Supabase
SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxx.supabase.co
SUPABASE_KEY=sua_service_role_key

# Banco de dados (PostgreSQL via Supabase)
# Encontre em: Supabase > Project Settings > Database > Connection string > URI
DATABASE_URL=postgresql://postgres:sua_senha@db.xxxxxxxxxxxxxxxxxxx.supabase.co:5432/postgres

# Google Gemini - sugestões de tratamento (primário)
# Obtenha em: https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=sua_chave_google

# OpenAI - transcrição de consultas via Whisper (fallback para sugestões)
# Obtenha em: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-sua_chave_openai
